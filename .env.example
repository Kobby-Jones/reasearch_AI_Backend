# ============================================================
#  RAI-Core (ResearchAI Backend) — environment configuration
#  Copy to `.env` and adjust. Values below are dev-friendly.
# ============================================================

# ---- App ----
APP_NAME="ResearchAI Backend (RAI-Core)"
ENVIRONMENT=development            # development | staging | production
DEBUG=true
API_PREFIX=/api/v1
# Comma-separated allowlist of browser origins. Use "*" for local dev only;
# in production set explicit origins, e.g. https://app.example.com,https://example.com
CORS_ORIGINS=*

# ---- Security ----
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ---- Database ----
# Production (mandated): PostgreSQL
# DATABASE_URL=postgresql+psycopg2://rai:rai@localhost:5432/rai_core
# Dev default: if left blank, the app falls back to a local SQLite file so it
# runs immediately after `pip install` + `uvicorn` with zero infra.
DATABASE_URL=

# Auto-create tables on startup when DEBUG=true (dev convenience).
# In production keep this false and use Alembic migrations.
AUTO_CREATE_TABLES=true

# ---- AI layer ----
# Provider is switchable. Use "mock" to run the whole system end-to-end
# WITHOUT any API key (deterministic structured output).
AI_PROVIDER=mock                   # mock | openai | claude
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Payments ----
PAYMENT_PROVIDER=paystack          # paystack | flutterwave
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
PAYMENT_CALLBACK_URL=http://localhost:8000/api/v1/payment/callback
DEFAULT_CURRENCY=GHS

# ---- Plan pricing (minor units: pesewas for GHS, kobo for NGN) ----
# Multiply the cedi price by 100.  GHS 50.00 -> 5000 ;  GHS 120.00 -> 12000
PRICE_BASIC=5000
PRICE_PREMIUM=12000
# Annual prices (minor units). Two months free vs paying monthly.
PRICE_BASIC_ANNUAL=50000
PRICE_PREMIUM_ANNUAL=120000

# ---- Uploads ----
UPLOAD_DIR=./storage/uploads
REPORT_DIR=./storage/reports
MAX_UPLOAD_MB=25

# ---- Optional infra ----
REDIS_URL=redis://localhost:6379/0
